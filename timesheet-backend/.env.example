# Timesheet Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:Niranjan@1093@localhost:5432/timesheet"

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Direct Email Connector Configuration

# Google Workspace OAuth
GMAIL_CLIENT_ID=your-google-workspace-client-id
GMAIL_CLIENT_SECRET=your-google-workspace-client-secret

# Microsoft Outlook OAuth
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret

# Zoho Mail OAuth
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret

# SendGrid API
SENDGRID_API_KEY=your-sendgrid-api-key

# Email Configuration (for API providers)
EMAIL_SENDER_EMAIL=noreply@yourcompany.com
EMAIL_REPLY_TO_EMAIL=support@yourcompany.com
EMAIL_SENDER_NAME=Your Company Name
EMAIL_ENABLE_NOTIFICATIONS=true

# Frontend URL (for OAuth callbacks)
FRONTEND_URL=http://localhost:5173

# Encryption Secret (for storing sensitive data)
ENCRYPTION_SECRET=your-encryption-secret-key-32-chars-long
